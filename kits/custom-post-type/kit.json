{
  "name": "Custom Post Type",
  "slug": "custom-post-type",
  "description": "Register a custom post type with taxonomy and meta box including nonce verification.",
  "category": "data",
  "tags": ["cpt", "taxonomy", "meta-box", "custom-fields", "admin"],
  "files": {
    "php": ["register-cpt.php", "meta-box.php"]
  },
  "variables": {
    "postTypeSlug": {
      "label": "Post type slug",
      "type": "string",
      "default": "service"
    },
    "postTypeName": {
      "label": "Post type name (plural)",
      "type": "string",
      "default": "Services"
    },
    "postTypeSingular": {
      "label": "Post type name (singular)",
      "type": "string",
      "default": "Service"
    },
    "menuIcon": {
      "label": "Dashicon class",
      "type": "string",
      "default": "dashicons-hammer"
    },
    "taxonomySlug": {
      "label": "Taxonomy slug",
      "type": "string",
      "default": "service_category"
    },
    "taxonomyName": {
      "label": "Taxonomy name (plural)",
      "type": "string",
      "default": "Service Categories"
    }
  },
  "variants": {},
  "dependencies": []
}
