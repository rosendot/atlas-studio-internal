{
  "name": "Landing — Restaurant",
  "slug": "landing-restaurant",
  "description": "Full landing page for a restaurant. Leads with a mood-setting hero video, surfaces fan-favorite dishes, teases the menu, shows atmosphere photos, builds trust with reviews, then funnels visitors to reservations via a map/hours block and final CTA. Warm, editorial, photo-forward.",
  "category": "landing",
  "tags": ["landing", "home", "restaurant", "food", "hero-video", "menu", "gallery", "reservations", "full-page"],
  "layout": "hero-first",
  "default_palette": "ember-hearth",
  "kits_used": [
    "header-transparent",
    "hero-video",
    "infinite-carousel",
    "menu-list",
    "grid-gallery",
    "testimonial-cards",
    "google-map-embed",
    "cta-banner",
    "footer-mega"
  ],
  "files": {
    "php": ["section.php"],
    "css": ["section.css"]
  },
  "variables": {
    "restaurantName": {
      "label": "Restaurant name",
      "type": "string",
      "default": "Trattoria del Fuoco"
    },
    "heroEyebrow": {
      "label": "Hero eyebrow",
      "type": "string",
      "default": "Wood-fired, family-run, since 1998"
    },
    "heroTitle": {
      "label": "Hero headline",
      "type": "string",
      "default": "A taste of old-world Italy, right in your neighborhood"
    },
    "heroBody": {
      "label": "Hero supporting text",
      "type": "string",
      "default": "Hand-rolled pasta, a wood-fired oven, and recipes passed down three generations. Walk-ins welcome, reservations encouraged."
    },
    "heroPrimaryLabel": {
      "label": "Primary CTA",
      "type": "string",
      "default": "Reserve a table"
    },
    "heroSecondaryLabel": {
      "label": "Secondary CTA",
      "type": "string",
      "default": "View the menu"
    },
    "favoritesTitle": {
      "label": "Fan favorites title",
      "type": "string",
      "default": "Fan favorites"
    },
    "favoritesSubtitle": {
      "label": "Fan favorites subtitle",
      "type": "string",
      "default": "The dishes our regulars order every time"
    },
    "menuTitle": {
      "label": "Menu teaser title",
      "type": "string",
      "default": "A few highlights from the menu"
    },
    "menuSubtitle": {
      "label": "Menu teaser subtitle",
      "type": "string",
      "default": "Seasonal, locally-sourced, made from scratch"
    },
    "galleryTitle": {
      "label": "Gallery title",
      "type": "string",
      "default": "Inside the restaurant"
    },
    "gallerySubtitle": {
      "label": "Gallery subtitle",
      "type": "string",
      "default": "Warm light, open kitchen, room for family"
    },
    "testimonialsTitle": {
      "label": "Testimonials title",
      "type": "string",
      "default": "What our guests say"
    },
    "visitTitle": {
      "label": "Visit / map title",
      "type": "string",
      "default": "Come visit"
    },
    "visitSubtitle": {
      "label": "Visit subtitle",
      "type": "string",
      "default": "Walk-ins welcome. Reservations recommended on weekends."
    },
    "visitAddress": {
      "label": "Address",
      "type": "string",
      "default": "142 Pearl Street, Hoboken, NJ 07030"
    },
    "visitPhone": {
      "label": "Phone",
      "type": "string",
      "default": "(201) 555-0142"
    },
    "visitEmail": {
      "label": "Email",
      "type": "string",
      "default": "reserve@trattoriadelfuoco.com"
    },
    "visitHours": {
      "label": "Hours",
      "type": "string",
      "default": "Tue–Sun 5pm–10pm · Closed Mon"
    },
    "ctaTitle": {
      "label": "Final CTA headline",
      "type": "string",
      "default": "Save your table tonight"
    },
    "ctaSubtitle": {
      "label": "Final CTA subtitle",
      "type": "string",
      "default": "Book online in under a minute, or call us directly."
    },
    "ctaPrimaryLabel": {
      "label": "Final CTA primary",
      "type": "string",
      "default": "Reserve now"
    },
    "ctaSecondaryLabel": {
      "label": "Final CTA secondary",
      "type": "string",
      "default": "Call (201) 555-0142"
    }
  }
